<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="/styles/main.css">
    <title>Dine SP</title>
    <link rel="icon" href="/images/logo.png">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg position-relative" style="z-index: 1050;">
      <div class="container-fluid position-relative">
        <a class="navbar-brand position-relative z-3" href="/">
            <img src="/images/logo.png" alt="Site logo" width="170" height="70">
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse w-100" id="navbarNav">
          <ul class="navbar-nav align-items-center absolute-center">
            <li class="nav-item">
              <a class="nav-link <%= activePage === 'home' ? 'active-link' : '' %>" href="/"><h1>Home</h1></a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= activePage === 'view' ? 'active-link' : '' %>" href="/view"><h1>View</h1></a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= activePage === 'review' ? 'active-link' : '' %>" href="/review"><h1>Review</h1></a>
            </li>
          </ul>

          <div class="d-flex align-items-center ms-auto justify-content-end mt-3 me-3 mt-lg-0">
          <% if (locals.user) { %>
            <div class="dropdown d-flex justify-content-center w-100 w-lg-auto ms-lg-auto mt-4 mt-lg-0 mb-3 mb-lg-0">
              <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="color: #d8cbb8;">
                  <i class="bi bi-person-circle fs-4 me-2"></i>
                  <span class="fw-medium" style="font-size: 1.05rem;"><%= user.username %></span>
              </a>
              
              <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userDropdown" style="background-color: #f4efeb; border-radius: 12px;">
                  <li class="px-3 py-2 text-center">
                      <span class="fw-bold d-block" style="color: #433c33; font-size: 1.1rem;"><%= user.username %> #<%= user.id %></span>
                  </li>
                  
                  <li><hr class="dropdown-divider" style="border-color: #d8cbb8; opacity: 0.5;"></li>
                  
                  <li>
                      <a class="dropdown-item d-flex align-items-center py-2" href="/profile" style="color: #433c33; font-weight: 500;">
                          <i class="bi bi-card-list me-3 fs-5"></i> My Reviews
                      </a>
                  </li>
                  
                  <li>
                      <a class="dropdown-item d-flex align-items-center py-2 text-danger fw-bold" href="/logout">
                          <i class="bi bi-box-arrow-right me-3 fs-5"></i> Logout
                      </a>
                  </li>
              </ul>
            </div>
          <% } else { %>
            <div class="row w-100 m-0 w-lg-auto ms-lg-auto mt-4 mt-lg-0 mb-3 mb-lg-0 flex-nowrap align-items-center justify-content-end">
              <div class="col-6 col-lg-auto d-flex justify-content-end pe-2 pe-lg-0">
                <a href="/login" class="text-decoration-none d-flex align-items-center auth-link" style="color: <%= activePage === 'login' ? '#ffffff' : '#d8cbb8' %>;">
                  <i class="bi bi-person-circle fs-4 me-2"></i>
                  <span class="fw-medium" style="font-size: 1.05rem;">Login</span>
                </a>
              </div>

              <div class="col-auto d-none d-lg-block px-3">
                <span class="opacity-75" style="color: #d8cbb8;">|</span>
              </div>

              <div class="col-6 col-lg-auto d-flex justify-content-start ps-2 ps-lg-0">
                <a href="/register" class="btn rounded-pill px-4 py-1 auth-btn fw-medium" style="border: 1px solid <%= activePage === 'register' ? '#ffffff' : '#d8cbb8' %>; color: <%= activePage === 'register' ? '#ffffff' : '#d8cbb8' %>; font-size: 1.05rem;">
                  Register
                </a>
              </div>
            </div>
          <% } %>
          </div>
        </div>
      </div>
    </nav>
  </body>
</html>